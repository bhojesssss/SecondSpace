  transform: translateX(-50%);
  width: 100%;
  max-width: 1440px;
}

#app > main {
  width: 100%;
  max-width: 1440px;
}

.app-wrapper {
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
}

/* Glassmorphism utility with an opaque fallback */
.glass-panel {
  background-color: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(0, 0, 0, 0.05);
}
@supports (backdrop-filter: blur(12px)) or (-webkit-backdrop-filter: blur(12px)) {
  .glass-panel {
    background-color: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
}

/* ─────────────────────────────────────────────────────────────────────────────
   Neo-brutalist primitives
   - 2px black border + hard offset shadow (no blur)
   - "press in" interaction on hover/active (button settles into shadow)
   ────────────────────────────────────────────────────────────────────────── */
.brutal-cta {
  border: 2px solid #111;
  box-shadow: 4px 4px 0 0 #111;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.brutal-cta:hover:not(:disabled) {
  transform: translate(2px, 2px);
  box-shadow: 2px 2px 0 0 #111;
}
.brutal-cta:active:not(:disabled) {
  transform: translate(4px, 4px);
  box-shadow: 0 0 0 0 #111;
}

/* Smaller variant for compact UI (chips, icon buttons, navbar CTA) */
.brutal-cta-sm {
  border: 2px solid #111;
  box-shadow: 3px 3px 0 0 #111;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.brutal-cta-sm:hover:not(:disabled) {
  transform: translate(1.5px, 1.5px);
  box-shadow: 1.5px 1.5px 0 0 #111;
}
.brutal-cta-sm:active:not(:disabled) {
  transform: translate(3px, 3px);
  box-shadow: 0 0 0 0 #111;
}

/* Static surface (cards, panels) — same border/shadow, no press interaction */
.brutal-surface {
  border: 2px solid #111;
  box-shadow: 4px 4px 0 0 #111;
}
.brutal-surface-sm {
  border: 2px solid #111;
  box-shadow: 3px 3px 0 0 #111;
}

/* Brand-coloured shadow variants (alt accent — used on auth card) */
.brutal-shadow-fashion { box-shadow: 4px 4px 0 0 #C1121F; }
.brutal-shadow-sports  { box-shadow: 4px 4px 0 0 #003049; }
</file>

