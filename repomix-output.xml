            :class="activeFilter === f.value ? 'filter-active' : 'filter-inactive glass-panel'"
          >
            <span>{{ f.label }}</span>
            <span class="filter-count" :class="activeFilter === f.value ? 'count-on' : 'count-off'">
              {{ counts[f.value] || 0 }}
