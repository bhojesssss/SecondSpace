  { label: 'Jerseys',     img: new URL('@/assets/ImgCard/t-shirt.avif',    import.meta.url).href },
]

// ── Recommended products (fashion) ────────────────────────────────────────────
const recommendedProducts = Array.from({ length: 8 }, (_, i) => ({
  id: i + 1,
  name: 'Insurgent Graphic Tee',
