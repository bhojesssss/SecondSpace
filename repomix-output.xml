<file path="src/assets/main.css">
@import 'tailwindcss';

@font-face {
  font-family: 'CalSans';
  src: url('@/assets/font/CALSANS-REGULAR.TTF') format('truetype');
  font-weight: 400;
  font-style: normal;
}

@font-face {
  font-family: 'Helvetica';
  src: url('@/assets/font/HELVETICA.TTF') format('truetype');
  font-weight: 400;
  font-style: normal;
}

@font-face {
  font-family: 'Helvetica';
  src: url('@/assets/font/HELVETICA-BOLD.TTF') format('truetype');
  font-weight: 700;
  font-style: normal;
}

@font-face {
  font-family: 'Helvetica';
  src: url('@/assets/font/HELVETICA-LIGHT-587EBE5A59211.TTF') format('truetype');
  font-weight: 300;
  font-style: normal;
}

@font-face {
  font-family: 'Helvetica';
  src: url('@/assets/font/HELVETICA-OBLIQUE.TTF') format('truetype');
  font-weight: 400;
  font-style: italic;
}

@theme {
  --color-bg: #fdf0d5;
  --color-fashion: #c1121f;
  --color-fashion-dark: #780000;
  --color-sports: #669bbc;
  --color-sports-dark: #003049;
  --color-white: #ffffff;
  --color-black: #111111;

  --font-display: 'CalSans', serif;
  --font-body: 'Helvetica', Arial, sans-serif;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
}

body {
  background-color: #fdf0d5;
  font-family: 'Helvetica', Arial, sans-serif;
  color: #111111;
  overflow-x: hidden;
}

/* Page transition */
.page-enter-active,
.page-leave-active {
  transition: all 0.35s ease;
}

.page-enter-from {
  opacity: 0;
  transform: translateY(16px);
}

.page-leave-to {
  opacity: 0;
  transform: translateY(-16px);
}

/* Scroll reveal */
.reveal {
  opacity: 0;
  transform: translateY(32px);
  transition:
    opacity 0.6s ease,
    transform 0.6s ease;
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.reveal-delay-1 {
  transition-delay: 0.1s;
}

.reveal-delay-2 {
  transition-delay: 0.2s;
}

.reveal-delay-3 {
  transition-delay: 0.3s;
}

.reveal-delay-4 {
  transition-delay: 0.4s;
}

/* Scrollbar */
::-webkit-scrollbar {
  width: 6px;
}

::-webkit-scrollbar-track {
  background: #fdf0d5;
}

::-webkit-scrollbar-thumb {
  background: #c1121f;
  border-radius: 3px;
}

#app {
  display: flex;
  flex-direction: column;
  align-items: center;
}

#app > nav.navbar-top {
  position: fixed;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 1440px;
}

#app > main {
  width: 100%;
  max-width: 1440px;
}

.app-wrapper {
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
}

/* Glassmorphism utility with an opaque fallback */
.glass-panel {
  background-color: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(0, 0, 0, 0.05);
}
@supports (backdrop-filter: blur(12px)) or (-webkit-backdrop-filter: blur(12px)) {
  .glass-panel {
    background-color: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
}

/* ─────────────────────────────────────────────────────────────────────────────
   Neo-brutalist primitives
   - 2px black border + hard offset shadow (no blur)
   - "press in" interaction on hover/active (button settles into shadow)
   ────────────────────────────────────────────────────────────────────────── */
.brutal-cta {
  border: 2px solid #111;
  box-shadow: 4px 4px 0 0 #111;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.brutal-cta:hover:not(:disabled) {
  transform: translate(2px, 2px);
  box-shadow: 2px 2px 0 0 #111;
}
.brutal-cta:active:not(:disabled) {
  transform: translate(4px, 4px);
  box-shadow: 0 0 0 0 #111;
}

/* Smaller variant for compact UI (chips, icon buttons, navbar CTA) */
.brutal-cta-sm {
  border: 2px solid #111;
  box-shadow: 3px 3px 0 0 #111;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.brutal-cta-sm:hover:not(:disabled) {
  transform: translate(1.5px, 1.5px);
  box-shadow: 1.5px 1.5px 0 0 #111;
}
.brutal-cta-sm:active:not(:disabled) {
  transform: translate(3px, 3px);
  box-shadow: 0 0 0 0 #111;
}

/* Static surface (cards, panels) — same border/shadow, no press interaction */
.brutal-surface {
  border: 2px solid #111;
  box-shadow: 4px 4px 0 0 #111;
}
.brutal-surface-sm {
  border: 2px solid #111;
  box-shadow: 3px 3px 0 0 #111;
}

/* Brand-coloured shadow variants (alt accent — used on auth card) */
.brutal-shadow-fashion { box-shadow: 4px 4px 0 0 #C1121F; }
.brutal-shadow-sports  { box-shadow: 4px 4px 0 0 #003049; }
</file>

