              <label class="default-check">
                <input type="checkbox" v-model="form.is_default" class="cb" />
                <span>Jadikan alamat utama</span>
              </label>
              <button type="submit" class="save-btn" :disabled="saving">{{ saving ? 'Menyimpan...' : 'Simpan Alamat' }}</button>
            </form>
          </div>
        </div>
      </transition>
    </template>

  </div>
